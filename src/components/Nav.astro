---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove leading slash
---

<nav class="fixed top-0 w-full z-50 bg-surface/60 backdrop-blur-xl border-b border-white/10 shadow-[0_0_40px_rgba(57,255,20,0.05)]">
  <div class="flex justify-between items-center px-8 py-6 max-w-full mx-auto">
    <div class="text-2xl font-black tracking-tighter text-primary uppercase font-sans">DatC.DEV</div>
    
    <div class="hidden md:flex gap-8 items-center font-sans font-medium tracking-tight">
      <a class={`transition-colors ${currentPath === '' ? 'text-primary font-bold border-b-2 border-primary pb-1' : 'text-on-surface-variant hover:text-white'}`} href="/">Home</a>
      <a class={`transition-colors ${currentPath === 'projects' ? 'text-primary font-bold border-b-2 border-primary pb-1' : 'text-on-surface-variant hover:text-white'}`} href="/projects">Projects</a>
      <a class={`transition-colors ${currentPath === 'skills' ? 'text-primary font-bold border-b-2 border-primary pb-1' : 'text-on-surface-variant hover:text-white'}`} href="/skills">Skills</a>
      <a class={`transition-colors ${currentPath === 'contact' ? 'text-primary font-bold border-b-2 border-primary pb-1' : 'text-on-surface-variant hover:text-white'}`} href="/contact">Contact</a>
      
      <button class="bg-primary text-surface px-6 py-2 rounded-full font-bold active:scale-95 transition-transform hover:shadow-[0_0_20px_rgba(57,255,20,0.3)]">
        Hire Me
      </button>
    </div>
    
    <div class="md:hidden">
      <span class="material-symbols-outlined text-white">menu</span>
    </div>
  </div>
</nav>
