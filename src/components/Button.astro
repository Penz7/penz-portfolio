---
interface Props {
  variant?: 'primary' | 'secondary' | 'tertiary';
  class?: string;
  href?: string;
}

const { variant = 'primary', class: className, href } = Astro.props;

const baseClasses = "px-8 py-4 rounded-full font-bold text-lg transition-all active:scale-95 inline-flex items-center justify-center";
const variantClasses = {
  primary: "bg-primary text-surface shadow-xl shadow-primary/10 hover:shadow-primary/30",
  secondary: "bg-surface-container-high/40 backdrop-blur-md border border-outline-variant/20 text-on-surface hover:bg-surface-container-high",
  tertiary: "text-primary text-sm tracking-widest uppercase hover:underline",
};

const Element = href ? 'a' : 'button';
---

<Element href={href} class={`${baseClasses} ${variantClasses[variant]} ${className}`}>
  <slot />
</Element>
