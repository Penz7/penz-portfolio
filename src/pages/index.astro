---
import { Image } from 'astro:assets';
import avatarImage from '../assets/avatar.png';
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Chip from "../components/Chip.astro";
import Card from "../components/Card.astro";
import MotionReveal from "../components/MotionReveal.tsx";
---

<BaseLayout title="DatC.DEV | Mobile Developer Portfolio">
  <Nav />
  
  <main class="relative min-h-screen bg-mesh pt-28">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-8 py-20 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 z-10 flex flex-col items-start">
        <MotionReveal client:load delay={0.1}>
            <Chip text="Available for new projects" class="mb-6" />
        </MotionReveal>
        
        <MotionReveal client:load delay={0.2}>
            <h1 class="font-sans font-extrabold text-5xl md:text-7xl leading-tight tracking-tighter mb-6 text-on-surface">
                Building Modern <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-white to-primary/80">Mobile Experiences</span>
            </h1>
        </MotionReveal>
        
        <MotionReveal client:load delay={0.3}>
            <p class="text-lg md:text-xl text-on-surface-variant max-w-xl mb-10 leading-relaxed font-sans">
                Developing reliable and high-performance applications with an emphasis on scalability and clean architecture.
            </p>
        </MotionReveal>
        
        <MotionReveal client:load delay={0.4}>
            <div class="flex flex-wrap gap-4">
                <Button variant="primary">Hire Me</Button>
                <Button variant="secondary" href="/projects">View Portfolio</Button>
            </div>
        </MotionReveal>
      </div>
      
      <!-- Hero Image / Mockup -->
      <div class="lg:col-span-5 relative group">
        <div class="absolute -inset-4 bg-gradient-to-r from-primary/10 to-transparent blur-3xl opacity-30 group-hover:opacity-50 transition-opacity"></div>
        <div class="relative glass-card rounded-[2rem] p-2 overflow-hidden aspect-square lg:aspect-[4/5] max-w-[400px] mx-auto">
            <Image alt="Professional portrait of Mobile Developer Cap Tan Dat" class="w-full h-full object-cover rounded-[1.8rem]" src={avatarImage} loading="eager" fetchpriority="high" />
            <div class="absolute inset-0 bg-gradient-to-t from-background/90 via-background/20 to-transparent flex flex-col justify-end p-8">
                <div class="h-1 w-12 bg-primary rounded-full mb-4"></div>
                <p class="text-sm font-sans uppercase tracking-widest text-primary mb-1">Mobile Developer</p>
                <h3 class="font-sans font-bold text-xl">Cap Tan Dat</h3>
            </div>
        </div>
      </div>
    </section>
    
    <!-- Tech Stack Horizontal Scroll -->
    <section class="bg-surface-container-low py-12 border-y border-white/5">
        <div class="max-w-7xl mx-auto px-8">
            <h4 class="font-sans text-xs uppercase tracking-[0.2em] text-on-surface-variant mb-8 text-center text-label-md">Mastering the Tech Ecosystem</h4>
            <div class="flex overflow-x-auto gap-12 pb-4 no-scrollbar items-center justify-start md:justify-center">
                <div class="flex flex-col items-center gap-3 shrink-0 grayscale hover:grayscale-0 transition-all opacity-60 hover:opacity-100 group">
                    <div class="w-16 h-16 rounded-2xl bg-surface-container flex items-center justify-center border border-outline-variant/10 group-hover:border-primary/40">
                        <i class="devicon-kotlin-plain colored text-4xl"></i>
                    </div>
                    <span class="text-xs font-sans tracking-[0.1em] font-semibold text-on-surface-variant uppercase">Kotlin</span>
                </div>
                <div class="flex flex-col items-center gap-3 shrink-0 grayscale hover:grayscale-0 transition-all opacity-60 hover:opacity-100 group">
                    <div class="w-16 h-16 rounded-2xl bg-surface-container flex items-center justify-center border border-outline-variant/10 group-hover:border-primary/40">
                        <i class="devicon-flutter-plain colored text-4xl"></i>
                    </div>
                    <span class="text-xs font-sans tracking-[0.1em] font-semibold text-on-surface-variant uppercase">Flutter</span>
                </div>
                <div class="flex flex-col items-center gap-3 shrink-0 grayscale hover:grayscale-0 transition-all opacity-60 hover:opacity-100 group">
                    <div class="w-16 h-16 rounded-2xl bg-surface-container flex items-center justify-center border border-outline-variant/10 group-hover:border-primary/40">
                        <i class="devicon-react-original colored text-4xl"></i>
                    </div>
                    <span class="text-xs font-sans tracking-[0.1em] font-semibold text-on-surface-variant uppercase">React Native</span>
                </div>
                <div class="flex flex-col items-center gap-3 shrink-0 grayscale hover:grayscale-0 transition-all opacity-60 hover:opacity-100 group">
                    <div class="w-16 h-16 rounded-2xl bg-surface-container flex items-center justify-center border border-outline-variant/10 group-hover:border-primary/40">
                        <i class="devicon-firebase-plain colored text-4xl"></i>
                    </div>
                    <span class="text-xs font-sans tracking-[0.1em] font-semibold text-on-surface-variant uppercase">Firebase</span>
                </div>
                <div class="flex flex-col items-center gap-3 shrink-0 grayscale hover:grayscale-0 transition-all opacity-60 hover:opacity-100 group">
                    <div class="w-16 h-16 rounded-2xl bg-surface-container flex items-center justify-center border border-outline-variant/10 group-hover:border-primary/40">
                        <i class="devicon-graphql-plain colored text-4xl"></i>
                    </div>
                    <span class="text-xs font-sans tracking-[0.1em] font-semibold text-on-surface-variant uppercase">GraphQL</span>
                </div>
            </div>
        </div>
    </section>
    
    <!-- About Me Section / Bento Grid -->
    <section class="max-w-7xl mx-auto px-8 py-24">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <!-- Large About Card -->
            <div class="md:col-span-2 flex">
                <Card variant="glass" class="w-full flex-1 flex flex-col justify-between">
                    <div>
                        <h2 class="font-sans font-extrabold text-3xl mb-6">Growth Mindset <br/><span class="text-primary">Technical Precision</span></h2>
                        <p class="text-on-surface-variant leading-relaxed mb-6">
                            I don’t just write code; I build and continuously refine systems. With over 2 years of experience in mobile development, I focus on bridging engineering and user-centric design while constantly learning and improving with every project.
                        </p>
                    </div>
                    <div class="flex gap-4">
                        <div class="px-4 py-2 bg-surface-container rounded-lg text-xs font-sans tracking-[0.1em] uppercase text-on-surface-variant border border-primary/10">2+ Years Exp</div>
                    </div>
                </Card>
            </div>
            
            <!-- Small Stat Card 1 -->
            <div class="flex">
                <Card variant="surface" glow={true} class="w-full flex-1 flex flex-col justify-center text-center items-center">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4" data-icon="speed">speed</span>
                    <h3 class="font-sans font-bold text-2xl mb-1 text-on-surface group-hover:text-primary transition-colors">Optimized</h3>
                    <p class="text-sm text-on-surface-variant font-sans uppercase tracking-[0.1em]">APP PERFORMANCE</p>
                </Card>
            </div>
            
            <!-- Small Stat Card 2 -->
            <div class="flex">
                <Card variant="surface" glow={true} class="w-full flex-1 flex flex-col justify-center text-center items-center">
                    <span class="material-symbols-outlined text-primary text-4xl mb-4" data-icon="code">code</span>
                    <h3 class="font-sans font-bold text-2xl mb-1 text-on-surface group-hover:text-primary transition-colors">Clean</h3>
                    <p class="text-sm text-on-surface-variant font-sans uppercase tracking-[0.1em]">CODE STRUCTURE</p>
                </Card>
            </div>
            
            <!-- New Personal Philosophy Section (Replaces Featured Project & Location Cards) -->
            <div class="md:col-span-4">
                <div class="glass-card rounded-[2.5rem] p-8 md:p-16 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 blur-[100px] -mr-32 -mt-32"></div>
                    <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary/5 blur-[80px] -ml-32 -mb-32"></div>
                    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
                        <div class="lg:col-span-5">
                            <h2 class="font-sans font-extrabold text-4xl md:text-6xl text-white leading-[1.1] tracking-tighter mb-8">
                                The Code <br/>Behind the <br/><span class="text-primary italic">Craft.</span>
                            </h2>
                            <div class="h-1 w-24 bg-primary rounded-full mb-8"></div>
                            <div class="flex flex-col gap-4">
                                <div class="flex items-center gap-4 group/item">
                                    <div class="w-10 h-10 rounded-full border border-primary/30 flex items-center justify-center group-hover/item:bg-primary/10 transition-colors">
                                        <span class="material-symbols-outlined text-primary text-xl" data-icon="bolt">bolt</span>
                                    </div>
                                    <span class="text-on-surface font-semibold uppercase tracking-widest text-xs">High-Performance Core</span>
                                </div>
                                <div class="flex items-center gap-4 group/item">
                                    <div class="w-10 h-10 rounded-full border border-primary/30 flex items-center justify-center group-hover/item:bg-primary/10 transition-colors">
                                        <span class="material-symbols-outlined text-primary text-xl" data-icon="auto_awesome">auto_awesome</span>
                                    </div>
                                    <span class="text-on-surface font-semibold uppercase tracking-widest text-xs">Scalable & Clean Systems</span>
                                </div>
                            </div>
                        </div>
                        <div class="lg:col-span-7">
                            <div class="space-y-6">
                                <p class="text-xl md:text-2xl text-on-surface font-medium leading-relaxed">
                                I believe software should be more than just functional; it should feel <span class="text-primary italic">intuitive</span> and <span class="text-primary italic">reliable</span>. 
                                </p>
                                <p class="text-lg text-on-surface-variant leading-relaxed">
                                My approach focuses on building maintainable and scalable applications while continuously learning and improving. In a fast-changing mobile landscape, I aim to balance solid engineering with user-centered design to create smooth and meaningful experiences.
                                </p>
                                <p class="text-lg text-on-surface-variant leading-relaxed">
                                Every interaction is carefully considered, every transition is purposeful, and every line of code is written with clarity and growth in mind. Whether working with Flutter or diving into native mobile, my goal is to deliver applications that are not only efficient, but also enjoyable to use.
                                </p>
                                <div class="pt-8 border-t border-white/10 mt-8 flex flex-wrap gap-8">
                                    <div>
                                        <p class="text-primary font-black text-3xl font-sans tracking-tighter">01</p>
                                        <p class="text-[10px] font-sans uppercase tracking-[0.2em] text-on-surface-variant mt-1 font-bold">Consistent Quality</p>
                                    </div>
                                    <div>
                                        <p class="text-primary font-black text-3xl font-sans tracking-tighter">02</p>
                                        <p class="text-[10px] font-sans uppercase tracking-[0.2em] text-on-surface-variant mt-1 font-bold">Performance-Oriented</p>
                                    </div>
                                    <div>
                                        <p class="text-primary font-black text-3xl font-sans tracking-tighter">03</p>
                                        <p class="text-[10px] font-sans uppercase tracking-[0.2em] text-on-surface-variant mt-1 font-bold">Continuous Learning</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
