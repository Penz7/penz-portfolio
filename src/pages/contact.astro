---
import { Image } from 'astro:assets';
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import MotionReveal from "../components/MotionReveal.tsx";
---

<BaseLayout title="Contact | DatC.DEV">
  <Nav />
  
  <main class="min-h-screen pt-32 pb-20 px-6 relative overflow-hidden flex-grow w-full max-w-7xl mx-auto">
    <!-- Abstract Tech Background -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-20">
        <div class="absolute top-1/4 -right-20 w-96 h-96 bg-primary/20 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 -left-20 w-96 h-96 bg-secondary/10 rounded-full blur-[120px]"></div>
    </div>
    
    <div class="max-w-7xl mx-auto relative z-10">
        <!-- Header Section -->
        <div class="mb-16 md:mb-24">
            <MotionReveal client:load delay={0.1}>
                <h1 class="font-sans text-5xl md:text-7xl font-extrabold tracking-tighter mb-6 text-on-surface">
                    Let's build something <br/>
                    <span class="text-gradient">amazing together!</span>
                </h1>
            </MotionReveal>
            <MotionReveal client:load delay={0.2}>
                <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl font-light leading-relaxed font-sans">
                    Have a concept in mind? I focus on turning ideas into refined, meaningful experiences — and I’m always open to sharing insights or exploring new possibilities together.
                </p>
            </MotionReveal>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
            <!-- Contact Form Column -->
            <div class="lg:col-span-7 z-20">
                <div class="glass-panel p-8 md:p-12 rounded-3xl border border-outline-variant/10 shadow-2xl relative">
                    <form id="contactForm" action="#" class="space-y-8" novalidate>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2 relative">
                                <label class="font-sans text-xs uppercase tracking-widest text-primary font-bold" for="name">Full Name</label>
                                <input class="w-full bg-surface-container-high border border-transparent rounded-xl px-6 py-4 text-on-surface focus:ring-2 focus:ring-primary/50 placeholder:text-outline-variant transition-all font-sans" id="name" name="name" placeholder="John Doe" type="text" required minlength="2"/>
                                <p class="text-[#ff3366] text-xs font-sans absolute -bottom-5 left-2 hidden" id="nameError">Please enter a valid name.</p>
                            </div>
                            <div class="space-y-2 relative">
                                <label class="font-sans text-xs uppercase tracking-widest text-primary font-bold" for="email">Email Address</label>
                                <input class="w-full bg-surface-container-high border border-transparent rounded-xl px-6 py-4 text-on-surface focus:ring-2 focus:ring-primary/50 placeholder:text-outline-variant transition-all font-sans" id="email" name="email" placeholder="john@example.com" type="email" required/>
                                <p class="text-[#ff3366] text-xs font-sans absolute -bottom-5 left-2 hidden" id="emailError">Please enter a valid email.</p>
                            </div>
                        </div>
                        <div class="space-y-2 relative">
                            <label class="font-sans text-xs uppercase tracking-widest text-primary font-bold" for="message">Your Message</label>
                            <textarea class="w-full bg-surface-container-high border border-transparent rounded-xl px-6 py-4 text-on-surface focus:ring-2 focus:ring-primary/50 placeholder:text-outline-variant transition-all resize-none font-sans" id="message" name="message" placeholder="Tell me about your project..." rows="5" required minlength="10"></textarea>
                            <p class="text-[#ff3366] text-xs font-sans absolute -bottom-5 left-2 hidden" id="messageError">Message must be at least 10 characters.</p>
                        </div>
                        <div class="pt-2">
                            <button id="submitBtn" class="group flex items-center justify-center gap-3 w-full md:w-auto px-10 py-5 bg-primary text-surface font-sans font-extrabold text-lg rounded-full hover:scale-105 active:scale-95 transition-all shadow-xl neon-glow-primary" type="submit">
                                <span id="btnText">Send Message</span>
                                <span id="btnIcon" class="material-symbols-outlined transition-transform group-hover:translate-x-1">send</span>
                            </button>
                            <p id="successMsg" class="text-primary text-sm font-sans font-bold hidden mt-4">Thank you! Your message has been sent.</p>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Info Column -->
            <div class="lg:col-span-5 space-y-8 z-20">
                <!-- Location Card -->
                <div class="bg-surface-container-low rounded-3xl overflow-hidden group border border-outline-variant/10">
                    <div class="h-64 relative overflow-hidden transition-all duration-700 bg-surface">
                        <div class="absolute inset-0 bg-primary/10 z-10 pointer-events-none transition-opacity group-hover:opacity-0"></div>
                        <iframe 
                            src="https://maps.google.com/maps?q=Phú%20Nhuận,%20Hồ%20Chí%20Minh&t=&z=13&ie=UTF8&iwloc=&output=embed" 
                            class="w-full h-full object-cover scale-110 group-hover:scale-100 transition-all duration-1000 grayscale group-hover:grayscale-0" 
                            style="border:0; filter: invert(90%) hue-rotate(180deg) brightness(85%) contrast(90%); pointer-events: none;" 
                            allowfullscreen="" 
                            loading="eager" 
                            referrerpolicy="no-referrer-when-downgrade"
                            title="Google Maps Location">
                        </iframe>
                        <div class="absolute bottom-6 left-6 z-20">
                            <div class="bg-surface/80 backdrop-blur-md px-4 py-2 rounded-full border border-primary/20 flex items-center gap-2 shadow-lg">
                                <span class="w-2 h-2 rounded-full bg-primary animate-pulse shadow-[0_0_8px_#39FF14]"></span>
                                <span class="text-sm font-sans font-bold text-on-surface tracking-tight">Phu Nhuan, Ho Chi Minh</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Details & Socials -->
                <div class="space-y-6 px-4">
                    <div class="flex items-center gap-6 group cursor-pointer">
                        <div class="w-12 h-12 rounded-2xl bg-surface-container-high flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-surface transition-all">
                            <span class="material-symbols-outlined">alternate_email</span>
                        </div>
                        <div>
                            <p class="font-sans text-xs uppercase tracking-widest text-outline-variant">Direct Email</p>
                            <p class="text-xl font-sans font-bold text-on-surface">tandatkt002@gmail.com</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const nameInput = document.getElementById('name') as HTMLInputElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const msgInput = document.getElementById('message') as HTMLTextAreaElement;
  
  const nameError = document.getElementById('nameError');
  const emailError = document.getElementById('emailError');
  const msgError = document.getElementById('messageError');
  const successMsg = document.getElementById('successMsg');
  
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const btnText = document.getElementById('btnText');
  const btnIcon = document.getElementById('btnIcon');

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function resetErrors() {
    [nameInput, emailInput, msgInput].forEach(el => {
      if(el) {
        el.classList.remove('border-[#ff3366]', 'bg-[#ff3366]/5');
        el.classList.add('border-transparent');
      }
    });
    [nameError, emailError, msgError].forEach(el => el?.classList.add('hidden'));
    successMsg?.classList.add('hidden');
  }

  function showError(input: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLElement | null) {
    input.classList.remove('border-transparent');
    input.classList.add('border-[#ff3366]', 'bg-[#ff3366]/5');
    errorEl?.classList.remove('hidden');
  }

  function hideError(input: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLElement | null) {
    if(input) {
      input.classList.remove('border-[#ff3366]', 'bg-[#ff3366]/5');
      input.classList.add('border-transparent');
    }
    errorEl?.classList.add('hidden');
  }

  // Reactive validation on input/blur
  nameInput?.addEventListener('input', () => {
    if (nameInput.value.trim().length >= 2) hideError(nameInput, nameError);
  });
  nameInput?.addEventListener('blur', () => {
    if (nameInput.value.trim().length >= 2) hideError(nameInput, nameError);
  });

  emailInput?.addEventListener('input', () => {
    if (emailRegex.test(emailInput.value.trim())) hideError(emailInput, emailError);
  });
  emailInput?.addEventListener('blur', () => {
    if (emailRegex.test(emailInput.value.trim())) hideError(emailInput, emailError);
  });

  msgInput?.addEventListener('input', () => {
    if (msgInput.value.trim().length >= 10) hideError(msgInput, msgError);
  });
  msgInput?.addEventListener('blur', () => {
    if (msgInput.value.trim().length >= 10) hideError(msgInput, msgError);
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    resetErrors();
    let isValid = true;

    if (nameInput.value.trim().length < 2) {
      showError(nameInput, nameError);
      isValid = false;
    }

    if (!emailRegex.test(emailInput.value.trim())) {
      showError(emailInput, emailError);
      isValid = false;
    }

    if (msgInput.value.trim().length < 10) {
      showError(msgInput, msgError);
      isValid = false;
    }

    if (isValid) {
      // Bắt đầu quá trình gửi (Giả lập)
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      if (btnText) btnText.innerText = 'Sending...';
      if (btnIcon) btnIcon.innerText = 'hourglass_empty';

      setTimeout(() => {
        // Gửi thành công
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        if (btnText) btnText.innerText = 'Send Message';
        if (btnIcon) btnIcon.innerText = 'send';
        
        form.reset();
        successMsg?.classList.remove('hidden');
        
        setTimeout(() => {
          successMsg?.classList.add('hidden');
        }, 5000);
      }, 1500);
    }
  });
</script>
