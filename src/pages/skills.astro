---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import MotionReveal from "../components/MotionReveal.tsx";
---

<BaseLayout title="Skills & Experience | DatC.DEV">
  <Nav />
  
  <main class="pt-40 pb-24 px-6 md:px-12 max-w-7xl mx-auto flex-grow w-full">
    <!-- Hero Title Section -->
    <section class="mb-20">
      <MotionReveal client:load delay={0.1}>
        <h1 class="text-5xl md:text-7xl font-sans font-extrabold tracking-tighter text-on-surface mb-6">
            Technical <span class="text-primary italic">Expertise</span> & Journey
        </h1>
      </MotionReveal>
      <MotionReveal client:load delay={0.2}>
        <p class="text-on-surface-variant max-w-2xl text-lg leading-relaxed font-sans">
            Focused on developing performant and scalable mobile applications, with a strong emphasis on clean architecture and continuous growth.
        </p>
      </MotionReveal>
    </section>

    <!-- Technical Skills Grid -->
    <section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-32">
        <!-- Mobile Skills Card -->
        <MotionReveal client:visible delay={0.1} className="flex h-full lg:col-span-1">
            <div class="skill-card bg-surface-container-low rounded-xl p-8 border border-outline-variant/50 hover:border-primary/60 transition-colors group w-full">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-3xl">smartphone</span>
                    </div>
                    <h2 class="text-2xl font-sans font-bold">Mobile</h2>
                </div>
                <div class="space-y-6">
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-flutter-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">Flutter</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">88%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="88"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-react-original colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">React Native</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">75%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="75"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-kotlin-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">Kotlin / Android</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">80%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="80"></div>
                        </div>
                    </div>
                </div>
                <div class="mt-8 flex flex-wrap gap-2">
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Flutter</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Dart</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">React Native</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Kotlin</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Jetpack Compose</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">GetX</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">BLoC</span>
                </div>
            </div>
        </MotionReveal>

        <!-- Web Card -->
        <MotionReveal client:visible delay={0.2} className="flex h-full lg:col-span-1">
            <div class="skill-card bg-surface-container-low rounded-xl p-8 border border-outline-variant/50 hover:border-primary/60 transition-colors group w-full">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-3xl">language</span>
                    </div>
                    <h2 class="text-2xl font-sans font-bold">Web</h2>
                </div>
                <div class="space-y-6">
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-nextjs-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">Next.js / React</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">80%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="80"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-typescript-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">TypeScript</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">82%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="82"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-tailwindcss-original colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">Tailwind CSS</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">90%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="90"></div>
                        </div>
                    </div>
                </div>
                <div class="mt-8 flex flex-wrap gap-2">
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">React</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Next.js</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">TypeScript</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Tailwind CSS</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Astro</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">HTML/CSS</span>
                </div>
            </div>
        </MotionReveal>

        <!-- Backend Card -->
        <MotionReveal client:visible delay={0.3} className="flex h-full lg:col-span-1">
            <div class="skill-card bg-surface-container-low rounded-xl p-8 border border-outline-variant/50 hover:border-primary/60 transition-colors group w-full">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-3xl">terminal</span>
                    </div>
                    <h2 class="text-2xl font-sans font-bold">Backend</h2>
                </div>
                <div class="space-y-6">
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-nestjs-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">NestJS</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">78%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="78"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-nodejs-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">Node.js / Express</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">82%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="82"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-mongodb-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">MongoDB</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">75%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="75"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between mb-2 items-center">
                            <div class="flex items-center gap-2">
                                <i class="devicon-firebase-plain colored text-lg"></i>
                                <span class="text-on-surface font-semibold font-sans">Firebase</span>
                            </div>
                            <span class="text-primary font-sans skill-pct">85%</span>
                        </div>
                        <div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="skill-bar h-full bg-primary rounded-full" data-width="85"></div>
                        </div>
                    </div>
                </div>
                <div class="mt-8 flex flex-wrap gap-2">
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">NestJS</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Node.js</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Express</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">MongoDB</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">Firebase</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">REST API</span>
                    <span class="px-3 py-1 bg-surface-container text-[10px] font-sans uppercase tracking-[0.1em] text-on-surface-variant border border-white/5">JWT</span>
                </div>
            </div>
        </MotionReveal>
    </section>

    <!-- Experience Timeline Section -->
    <section class="relative">
        <h2 class="text-4xl font-sans font-extrabold mb-16 flex items-center gap-4">
            Professional <span class="text-primary">Trajectory</span>
        </h2>
        
        <!-- Timeline Vertical Line -->
        <div class="absolute left-0 md:left-1/2 top-24 bottom-0 w-px bg-gradient-to-b from-primary via-primary/50 to-transparent hidden md:block"></div>
        
        <div class="space-y-12">
            <!-- Role 1 -->
            <MotionReveal client:visible delay={0.1}>
                <div class="relative flex flex-col md:flex-row md:justify-between items-start md:items-center group">
                    <div class="md:w-5/12 order-2 md:order-1">
                        <div class="bg-surface-container p-8 rounded-xl border border-outline-variant group-hover:bg-surface-container-high transition-colors">
                            <div class="flex justify-between items-start mb-4">
                                <h3 class="text-xl font-sans font-bold text-on-surface">Mobile Developer</h3>
                                <span class="text-primary font-sans text-[10px] tracking-widest font-bold uppercase">Present</span>
                            </div>
                            <h4 class="text-primary font-semibold mb-3 font-sans">DatC Team</h4>
                            <p class="text-on-surface-variant text-sm leading-relaxed mb-6 font-sans">
                                Building high-performance mobile applications using Flutter and Kotlin. Focused on clean architecture, state management, and delivering smooth user experiences across iOS and Android.
                            </p>
                        </div>
                    </div>
                    <div class="z-10 absolute left-[-8px] md:left-1/2 md:-ml-3 w-6 h-6 rounded-full bg-primary flex items-center justify-center order-1 md:order-2 mb-6 md:mb-0 timeline-glow">
                        <div class="w-3 h-3 rounded-full bg-surface"></div>
                    </div>
                    <div class="md:w-5/12 order-3 hidden md:block pl-12">
                        <span class="text-on-surface-variant/20 font-sans font-black text-6xl italic select-none">2024</span>
                    </div>
                </div>
            </MotionReveal>

            <!-- Role 2 -->
            <MotionReveal client:visible delay={0.2}>
                <div class="relative flex flex-col md:flex-row md:justify-between items-start md:items-center group">
                    <div class="md:w-5/12 order-3 md:order-3">
                        <div class="bg-surface-container p-8 rounded-xl border border-outline-variant group-hover:bg-surface-container-high transition-colors">
                            <div class="flex justify-between items-start mb-4">
                                <h3 class="text-xl font-sans font-bold text-on-surface">Junior Mobile Developer</h3>
                                <span class="text-primary font-sans text-[10px] tracking-widest font-bold uppercase">2023 — 2024</span>
                            </div>
                            <h4 class="text-primary font-semibold mb-3 font-sans">Freelance / Personal Projects</h4>
                            <p class="text-on-surface-variant text-sm leading-relaxed mb-6 font-sans">
                                Developed cross-platform mobile apps using Flutter and integrated backend APIs with Node.js and Firebase. Continuously improved skills through real-world projects and open-source contributions.
                            </p>
                        </div>
                    </div>
                    <div class="z-10 absolute left-[-8px] md:left-1/2 md:-ml-3 w-6 h-6 rounded-full bg-primary flex items-center justify-center order-1 md:order-2 mb-6 md:mb-0 timeline-glow">
                        <div class="w-3 h-3 rounded-full bg-surface"></div>
                    </div>
                    <div class="md:w-5/12 order-2 hidden md:block text-right pr-12">
                        <span class="text-on-surface-variant/20 font-sans font-black text-6xl italic select-none">2023</span>
                    </div>
                </div>
            </MotionReveal>
            
        </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .skill-bar {
    width: 0%;
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const card = entry.target;
        card.querySelectorAll('.skill-bar').forEach((bar) => {
          const target = bar.getAttribute('data-width');
          (bar as HTMLElement).style.width = target + '%';
        });
        observer.unobserve(card);
      }
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.skill-card').forEach((card) => {
    observer.observe(card);
  });
</script>
